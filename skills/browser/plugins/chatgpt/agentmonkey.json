{
  "name": "chatgpt",
  "description": "Helpers for interacting with ChatGPT web UI",
  "routes": [
    {
      "match": ["*://chatgpt.com/c/*"],
      "browser": "conversation.ts",
      "node": "conversation.node.ts"
    },
    {
      "match": ["*://chatgpt.com/share/*"],
      "browser": "share.ts"
    },
    {
      "match": ["*://chatgpt.com/*"],
      "browser": "common.ts"
    }
  ]
}
